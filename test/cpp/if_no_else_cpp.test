# IF X > 5
# CHECK: int8_t {{.*}} = 5;
# CHECK: bool {{.*}} = {{.*}} > {{.*}};
# CHECK: if ({{.*}}) {
# CHECK: "GREATER THAN FIVE"
# CHECK: std::cout
# CHECK: }
# CHECK: return;
# CHECK: }
