# Test: IF without ELSE: from COBOL to C++
# REQUIRES: koopa, mlir-translate
# RUN: %cobol-translate %S/inputs/if_no_else.cbl --emit=emitc -o %S/Output/if_no_else.mlir && \
# RUN: %mlir-translate --mlir-to-cpp %S/Output/if_no_else.mlir | FileCheck %s

# CHECK: void IFNOELSE() {
