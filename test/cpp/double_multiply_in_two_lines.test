# Test: GO TO with paragraphs: from COBOL to C++
# REQUIRES: koopa, mlir-translate
# RUN: %cobol-translate %S/../examples/double_multiply_in_two_lines.cbl --emit=emitc -o %S/Output/double_multiply_in_two_lines.mlir && \
# RUN: %mlir-translate --mlir-to-cpp %S/Output/double_multiply_in_two_lines.mlir | FileCheck %s


#CHECK: #include <cstdint>
#CHECK: void display() {
#CHECK:   int8_t v1 = 32;
#CHECK:   int8_t v2 = -20;
#CHECK:   int8_t v3 = 22;
#CHECK:   int8_t v4 = v1;
#CHECK:   int8_t v5 = v2;
#CHECK:   int8_t v6 = v4 * v5;
#CHECK:   v2 = v6;
#CHECK:   int8_t v7 = v2;
#CHECK:   int8_t v8 = v3;
#CHECK:   int8_t v9 = v7 * v8;
#CHECK:   v3 = v9;
#CHECK:   return;
#CHECK: }