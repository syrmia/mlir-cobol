# Test: Variable declarations with PIC clause and DISPLAY with one arg: from COBOL to C++
# REQUIRES: koopa, mlir-translate
# RUN: %cobol-translate %S/../examples/display_substring.cbl --emit=emitc -o %S/Output/display_substring.mlir | \
# RUN: %mlir-translate --mlir-to-cpp %S/Output/display_substring.mlir | FileCheck %s

#CHECK: #include <iostream>
#CHECK: #include <string>
#CHECK: void prog() {
#CHECK:   std::string v1 = "abcd";
#CHECK:   std::cout << v1.substr(0, 3);
#CHECK:   return;
#CHECK: }