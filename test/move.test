# CHECK: value = 0
# CHECK: "cobol.constant"
# CHECK: value = 2
# CHECK: "cobol.move"
# CHECK: "cobol.constant"
# CHECK: value = "mau"
# CHECK: "cobol.move"
# CHECK: "cobol.constant"
# CHECK: value = 8
# CHECK: "cobol.move"
# CHECK: "cobol.stop"
# CHECK: sym_name = "moves"
