# Test: IF-ELSE control flow with MOVE and comparison
# REQUIRES: koopa
# RUN: %cobol-translate %S/../examples/ifelse.cbl 2>&1 | FileCheck %s

# CHECK: builtin.module
# CHECK: "cobol.func"
# CHECK: "cobol.declare"
# CHECK: sym_name = "OPERAND1"
# CHECK: "cobol.declare"
# CHECK: sym_name = "OPERAND2"
# CHECK: "cobol.constant"
# CHECK: "cobol.move"
# CHECK: "cobol.is"
# CHECK: kind = "numeric"
# CHECK: arith.cmpi sgt
# CHECK: arith.andi
# CHECK: scf.if
# CHECK: "cobol.display"
# CHECK: } else {
# CHECK: "cobol.display"
# CHECK: "cobol.stop"
# CHECK: sym_name = "HELLOWORD"
