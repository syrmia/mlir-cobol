# Test: Variable declarations with PIC clause and DISPLAY with one arg
# REQUIRES: koopa
# RUN: %cobol-translate %S/../examples/display_one.cbl 2>&1 | FileCheck %s

# CHECK: builtin.module
# CHECK: "cobol.func"
# CHECK: "cobol.declare"
# CHECK: value = 25
# CHECK: "cobol.declare"
# CHECK: value = "\"Duke\""
# CHECK: "cobol.display"
# CHECK: "cobol.display"
# CHECK: "cobol.stop"
# CHECK: sym_name = "display"
