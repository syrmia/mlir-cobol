# Test: Variable declarations with PIC clause and DISPLAY with multiple args
# REQUIRES: koopa
# RUN: %cobol-translate %S/../examples/display_mul.cbl 2>&1 | FileCheck %s

# CHECK: builtin.module
# CHECK: "cobol.func"
# CHECK: "cobol.declare"
# CHECK: value = "'Duke'"
# CHECK: "cobol.declare"
# CHECK: value = 32
# CHECK: "cobol.constant"
# CHECK: value = "Name: "
# CHECK: "cobol.display"
# CHECK: "cobol.constant"
# CHECK: value = "Age: "
# CHECK: "cobol.display"
# CHECK: "cobol.stop"
# CHECK: sym_name = "display"
