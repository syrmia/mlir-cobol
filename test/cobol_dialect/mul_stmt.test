# Test: MULTIPLY B BY A
# REQUIRES: koopa
# RUN: %cobol-translate %S/inputs/mul_stmt.cbl 2>&1 | FileCheck %s

# CHECK: builtin.module {
# CHECK-NEXT:   "cobol.func"() ({
# CHECK-NEXT:     %0 = "cobol.declare"() {value = 2 : i8, level = 77 : i8} : () -> !cobol.decimal<2 : i32, 0 : i32>
# CHECK-NEXT:     %1 = "cobol.declare"() {value = 20 : i8, level = 77 : i8} : () -> !cobol.decimal<2 : i32, 0 : i32>
# CHECK-NEXT:     %2 = "cobol.mul"(%0, %1) <{kind = "mul_by"}> : (!cobol.decimal<2 : i32, 0 : i32>, !cobol.decimal<2 : i32, 0 : i32>) -> !cobol.decimal<2 : i32, 0 : i32>
# CHECK-NEXT:     %3 = "cobol.constant"() {value = "B: "} : () -> !cobol.string<3 : i32>
# CHECK-NEXT:     "cobol.display"(%3, %1) : (!cobol.string<3 : i32>, !cobol.decimal<2 : i32, 0 : i32>) -> ()
# CHECK-NEXT:     "cobol.stop"() : () -> ()
# CHECK-NEXT:   }) {sym_name = "MULSTMT", function_type = () -> ()} : () -> ()
# CHECK-NEXT: }
