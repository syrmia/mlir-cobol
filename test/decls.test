# Test: Variable declarations with PIC clause and DISPLAY
# REQUIRES: koopa
# RUN: %cobol-translate %S/../examples/decls.cbl 2>&1 | FileCheck %s

# CHECK: builtin.module
# CHECK: "cobol.func"
# CHECK: "cobol.declare"
# CHECK: sym_name = "WS-NAME"
# CHECK: "cobol.declare"
# CHECK: sym_name = "WS-AGE"
# CHECK: "cobol.display"
# CHECK: "cobol.stop"
# CHECK: sym_name = "SimpleVariable"
